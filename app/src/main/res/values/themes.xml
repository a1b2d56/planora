<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Planora" parent="Theme.AppCompat.DayNight.NoActionBar" tools:ignore="NewApi">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
    <style name="Theme.Planora.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/branding_midnight</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.Planora</item>
    </style>
</resources>
